# ─────────────────────────────────────────────────────────────
# CVA IT Policy Platform — Environment Variables
# Copy this file to .env and fill in all values before running.
# For Vercel deployment, set these in the Vercel dashboard.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Local:  postgresql://user:password@localhost:5432/cva_policy_db
# Neon:   copy from Neon dashboard → Connection string (use the "pooled" URL)
DATABASE_URL=""

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Full URL of your deployment (no trailing slash)
# Vercel: https://your-project.vercel.app  or your custom domain
NEXTAUTH_URL="http://localhost:3000"

# Web Push (VAPID) — for browser push notifications
# Generate a new pair with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:it@yourdomain.com"

# Optional: Email (SMTP settings stored in DB, configured via Admin > Notifications)
